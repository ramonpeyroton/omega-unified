# ─── Anthropic API Key (Claude — project reports + cost projection) ─
VITE_ANTHROPIC_KEY=

# ─── Groq API Key (Jarvis chat, Llama 3.3) ─────────────────────────
VITE_GROQ_API_KEY=

# ─── DocuSign (client-side, safe to expose) ────────────────────────
VITE_DOCUSIGN_INTEGRATION_KEY=
VITE_DOCUSIGN_ACCOUNT_ID=
VITE_DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
VITE_DOCUSIGN_REDIRECT_URI=http://localhost:5174/docusign/callback

# ─── DocuSign (server-side — used by Vercel Functions only) ────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE=https://account-d.docusign.net
# RSA private key from DocuSign App. Keep newlines as real \n.
DOCUSIGN_PRIVATE_KEY=
# Optional: set if DocuSign Connect HMAC signing is enabled
DOCUSIGN_HMAC_SECRET=

# ─── Supabase (server-side — used by the webhook) ──────────────────
SUPABASE_URL=https://jbdtdyxzfejhotbjdnwm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Slack (server-side — used by the chat-per-project feature) ────
# Bot User OAuth Token from https://api.slack.com/apps → Your App →
# OAuth & Permissions → "Bot User OAuth Token" (starts with xoxb-).
# Required scopes (granted in OAuth & Permissions → Scopes → Bot Token):
#   channels:history, channels:read, chat:write, files:read, files:write
SLACK_BOT_TOKEN=
# Signing secret used to verify Events API callbacks (only needed when
# we add real-time updates in v2). Copy from Basic Information →
# App Credentials → Signing Secret.
SLACK_SIGNING_SECRET=
